# ############################################################### #
# APP SWITCHING                                                   #
# ############################################################### #

alt - a : osascript -e 'tell application "Google Chrome" to activate'
alt - s : osascript -e 'tell application "Code" to activate'
alt - d : osascript -e 'tell application "IntelliJ IDEA CE" to activate'
alt - f : osascript -e 'tell application "Studio 3T" to activate'
alt - q : osascript -e 'tell application "Slack" to activate'
alt - w : osascript -e 'tell application "Terminal" to activate'
alt - e : osascript -e 'tell application "Insomnia" to activate'
alt - r : osascript -e 'tell application "PyCharm CE" to activate'
alt - z : osascript -e 'tell application "TablePlus" to activate'
alt - o : osascript -e 'tell application "Finder" to activate'
alt - i : osascript -e 'tell application "Notes" to activate'
alt - k : osascript -e 'tell application "Claude" to activate'

# ############################################################### #
# TERMINAL MODE (alt - t to enter, escape to exit)                #
# ############################################################### #

:: terminal @ : osascript -e 'display notification "Terminal mode active" with title "skhd" subtitle "b=base64 encode | d=base64 decode | u=uuid | esc=exit"'

alt - t ; terminal

terminal < b : pbpaste | base64 | tr -d '\n' | pbcopy; \
              osascript -e 'display notification "Clipboard encoded to base64" with title "skhd"'; \
              skhd -k "escape"

terminal < d : pbpaste | base64 -D | tr -d '\n' | pbcopy; \
              osascript -e 'display notification "Clipboard decoded from base64" with title "skhd"'; \
              skhd -k "escape"

terminal < u : uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '\n' | pbcopy; \
              osascript -e 'display notification "UUID copied to clipboard" with title "skhd"'; \
              skhd -k "escape"

terminal < escape ; default

# ############################################################### #
# NOTIFICATIONS                                                   #
# ############################################################### #

alt - n : osascript -e \
    'set timeStr to (current date) as string' -e \
    'set batteryLevel to do shell script "pmset -g batt | grep -o \"[0-9]\\{1,3\\}%\""' -e \
    'display notification ("Battery: " & batteryLevel) with title timeStr'
